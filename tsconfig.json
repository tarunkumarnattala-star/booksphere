{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-preview-3000/types/**/*.ts",
    ".next-preview-3000/dev/types/**/*.ts",
    ".next-booksphere-preview/types/**/*.ts",
    ".next-booksphere-preview/dev/types/**/*.ts",
    ".next-launch-check/types/**/*.ts",
    ".next-launch-check/dev/types/**/*.ts",
    ".next-launch-final/types/**/*.ts",
    ".next-launch-final/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next*"
  ]
}
